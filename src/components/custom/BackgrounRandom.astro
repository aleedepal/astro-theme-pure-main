<div
  class="pointer-events-none fixed inset-0 print:hidden"
  style="mask-image: radial-gradient(circle, transparent, black); -webkit-mask-image: radial-gradient(circle, transparent, black);"
>
  <canvas id="artCanvas"></canvas>
</div>

<script>
  let artCanvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let steps: Function[] = [];
  let prevSteps: Function[] = [];
  let rafId: number | null = null;

  const r180 = Math.PI;
  const r90 = Math.PI / 2;
  const r15 = Math.PI / 12;
  const MIN_BRANCH = 30;
  const len = 6;

  const darkThemeColors = ['hsla(0, 96.40%, 43.90%, 0.85)', 'hsla(0, 100.00%, 51.00%, 0.25)', 'hsla(0, 100.00%, 50.00%, 0.99)'];
  const lightThemeColors = ['hsla(45, 90%, 40%, 0.35)', 'hsla(190, 100%, 20%, 0.25)', 'hsla(10, 80%, 40%, 0.25)'];

  const size = { width: 0, height: 0 };

  const initCanvas = () => {
    artCanvas = document.getElementById('artCanvas') as HTMLCanvasElement;
    if (!artCanvas) return;
    ctx = artCanvas.getContext('2d');
    const dpi = window.devicePixelRatio || 1;
    size.width = window.innerWidth;
    size.height = window.innerHeight;

    artCanvas.style.width = `${size.width}px`;
    artCanvas.style.height = `${size.height}px`;
    artCanvas.width = dpi * size.width;
    artCanvas.height = dpi * size.height;
    ctx?.scale(dpi, dpi);
  };

  const polar2cart = (x = 0, y = 0, r = 0, theta = 0) => [
    x + r * Math.cos(theta),
    y + r * Math.sin(theta)
  ];

  const step = (x: number, y: number, rad: number, counter = { value: 0 }) => {
    if (!ctx) return;
    const length = Math.random() * len;
    counter.value += 1;
    const [nx, ny] = polar2cart(x, y, length, rad);

    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(nx, ny);
    ctx.stroke();

    const rad1 = rad + Math.random() * r15;
    const rad2 = rad - Math.random() * r15;

    if (nx < -100 || nx > size.width + 100 || ny < -100 || ny > size.height + 100) return;

    const rate = counter.value <= MIN_BRANCH ? 0.8 : 0.5;
    if (Math.random() < rate) steps.push(() => step(nx, ny, rad1, counter));
    if (Math.random() < rate) steps.push(() => step(nx, ny, rad2, counter));
  };

  const frame = () => {
    prevSteps = steps;
    steps = [];
    if (!prevSteps.length) return;
    prevSteps.forEach((i) => {
      if (Math.random() < 0.5) steps.push(i);
      else i();
    });
    rafId = requestAnimationFrame(frame);
  };

  const start = () => {
    if (!artCanvas || !ctx) return;
    if (rafId) cancelAnimationFrame(rafId);

    ctx.clearRect(0, 0, artCanvas.width, artCanvas.height);
    steps = [];

    const isDark = document.documentElement.classList.contains('dark');
    const palette = isDark ? darkThemeColors : lightThemeColors;
    ctx.lineWidth = 1;
    ctx.strokeStyle = palette[Math.floor(Math.random() * palette.length)];

    const randomMiddle = () => Math.random() * 0.6 + 0.2;
    const newSeeds = [
      () => step(randomMiddle() * size.width, -5, r90),
      () => step(randomMiddle() * size.width, size.height + 5, -r90),
      () => step(-5, randomMiddle() * size.height, 0),
      () => step(size.width + 5, randomMiddle() * size.height, r180)
    ];

    steps.push(...(size.width < 500 ? newSeeds.slice(0, 2) : newSeeds));
    frame();
  };

  const handleResize = () => {
    initCanvas();
    start();
  };

  // Logic to handle "Route Changes" in Astro 
  // This works best if you are using View Transitions.
  document.addEventListener('astro:page-load', () => {
    initCanvas();
    start();
    window.addEventListener('resize', handleResize);
  });

  // Cleanup for View Transitions
  document.addEventListener('astro:before-preparation', () => {
    window.removeEventListener('resize', handleResize);
    if (rafId) cancelAnimationFrame(rafId);
  });

  // Basic initialization for non-view-transition sites
  initCanvas();
  start();
  window.addEventListener('resize', handleResize);
</script>

<style>
  canvas {
    display: block;
  }
</style>