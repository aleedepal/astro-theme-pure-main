---
const playlist = [
  { title: "Yaad Aye Bewafa", artist: "Robin", src: "https://www.youtube.com/watch?v=8fneVtzl_FU&list=RD8fneVtzl_FU&start_radio=1" },
  { title: "Wingray Waal | Saraiki.", artist: "Saraiki", src: "src/assets/music/videoplayback (1).webm" },
  { title: "Kalay Cholay | Saraiki.", artist: "Saraiki", src: "src/assets/music/videoplayback (2).webm" }
];
---

<div class="music-player-container" transition:persist="player-widget">
  <div class="player-capsule collapsed" id="player-capsule">
    
    <div class="status-icon" id="master-play-btn">
        <div class="icon-inner" id="master-icon">▶</div>
    </div>

    <div class="player-content">
      <div class="interaction-layer">
        <div class="title-area" id="info-display">
            <span id="track-title" class="track-title">{playlist[0].title}</span>
        </div>

        <div class="expanded-controls">
          <button id="prev-btn" class="nav-btn">⏮</button>
          <span class="now-playing-label" id="collapse-trigger">Now Playing</span>
          <button id="next-btn" class="nav-btn">⏭</button>
        </div>
      </div>

      <div class="player-bottom">
        <input type="range" id="progress-bar" value="0" max="100" class="progress-bar" />
      </div>
    </div>

     <audio id="main-audio" transition:persist="player-audio"></audio>
  </div>
</div>

<script define:vars={{ playlist }}>
  // Defined outside to persist across Astro view transitions
  let currentIndex = 0;

  const initPlayer = () => {
    const audio = document.getElementById('main-audio');
    const capsule = document.getElementById('player-capsule');
    const masterBtn = document.getElementById('master-play-btn');
    const masterIcon = document.getElementById('master-icon');
    const expandTrigger = document.getElementById('info-display');
    const collapseTrigger = document.getElementById('collapse-trigger');
    const nextBtn = document.getElementById('next-btn');
    const prevBtn = document.getElementById('prev-btn');
    const progressBar = document.getElementById('progress-bar');

    if (!audio || !capsule) return;

    const loadSong = (index) => {
      currentIndex = index;
      audio.src = playlist[index].src;
      const titleElement = document.getElementById('track-title');
      if (titleElement) titleElement.innerText = playlist[index].title;
      audio.load();
    };

    // Only load the first song if the audio player is totally fresh
    if (!audio.src || audio.src === '') {
      loadSong(0);
    }

    // --- FIX: AUTOPLAY NEXT SONG ---
    audio.onended = () => {
      currentIndex = (currentIndex + 1) % playlist.length;
      loadSong(currentIndex);
      audio.play();
      masterIcon.innerText = "||";
    };

    // Sync icon state when moving between pages
    if (!audio.paused) {
      masterIcon.innerText = "||";
    } else {
      masterIcon.innerText = "▶";
    }

    const toggleCapsule = (e) => {
      e.stopPropagation();
      capsule.classList.toggle('collapsed');
    };

    expandTrigger.onclick = toggleCapsule;
    collapseTrigger.onclick = toggleCapsule;

    masterBtn.onclick = (e) => {
      e.stopPropagation();
      if (audio.paused) {
        audio.play();
        masterIcon.innerText = "||";
      } else {
        audio.pause();
        masterIcon.innerText = "▶";
      }
    };

    audio.ontimeupdate = () => {
      if (audio.duration) progressBar.value = (audio.currentTime / audio.duration) * 100;
    };

    progressBar.oninput = () => {
      if (audio.duration) audio.currentTime = (progressBar.value / 100) * audio.duration;
    };

    nextBtn.onclick = (e) => {
      e.stopPropagation();
      currentIndex = (currentIndex + 1) % playlist.length;
      loadSong(currentIndex);
      audio.play();
      masterIcon.innerText = "||";
    };

    prevBtn.onclick = (e) => {
      e.stopPropagation();
      currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
      loadSong(currentIndex);
      audio.play();
      masterIcon.innerText = "||";
    };
  };

  // Run on initial page load
  initPlayer();

  // Run every time Astro swaps the page content
  document.addEventListener('astro:page-load', initPlayer);
</script>

<style>
  .music-player-container {
    position: fixed;
    bottom: 1.5rem;
    left: 1rem;
    z-index: 1000;
  }

  .player-capsule {
    display: flex;
    align-items: center;
    background: #ffffffd1;
    backdrop-filter: blur(5px);
    padding: 8px 14px;
    border-radius: 18px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    width: 240px;
    height: 60px;
    overflow: hidden;
  }

  .player-capsule.collapsed {
    width: 180px;
    height: 40px;
    border-radius: 50px;
    padding: 4px 12px;
  }

  .status-icon {
    width: 30px;
    height: 30px;
    background: #1a1a2e;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
  }

  .icon-inner { color: white; font-size: 9px; }

  .player-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    margin-left: 10px;
    justify-content: center;
  }

  .interaction-layer {
    display: flex;
    align-items: center;
    min-height: 20px;
  }

  .expanded-controls { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    width: 100%; 
  }

  .title-area { cursor: pointer; display: none; line-height: 1; }
  
  .player-capsule.collapsed .title-area { display: block; }
  .player-capsule.collapsed .expanded-controls { display: none; }

  .track-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: #333;
    white-space: nowrap;
  }

  .now-playing-label {
    font-size: 0.65rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
  }

  .player-bottom {
    margin-top: 4px;
    height: 12px;
    display: flex;
    align-items: center;
  }

  .player-capsule.collapsed .player-bottom { display: none; }

  .progress-bar {
    width: 100%;
    height: 3px;
    accent-color: #1a1a2e;
    cursor: pointer;
    margin: 0;
  }

  .nav-btn {
    background: none;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    color: #444;
    padding: 2px 5px;
    transition: transform 0.2s;
  }

  .nav-btn:hover { transform: scale(1.1); }
</style>